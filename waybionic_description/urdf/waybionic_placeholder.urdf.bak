<?xml version="1.0"?>
<robot name="waybionic">

  <link name="world"/>

  <!-- Base -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.2 0.2 0.05"/></geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <material name="dark_gray"><color rgba="0.3 0.3 0.3 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.2 0.2 0.05"/></geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0.025"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Link 1: lower arm -->
  <link name="link_1">
    <visual>
      <geometry><cylinder radius="0.04" length="0.3"/></geometry>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <material name="blue"><color rgba="0.1 0.3 0.8 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.3"/></geometry>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0.15"/>
      <inertia ixx="0.008" iyy="0.008" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.967" upper="2.967" effort="10.0" velocity="1.0"/>
  </joint>

  <!-- Link 2: upper arm -->
  <link name="link_2">
    <visual>
      <geometry><cylinder radius="0.035" length="0.25"/></geometry>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <material name="light_blue"><color rgba="0.3 0.5 0.9 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.035" length="0.25"/></geometry>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0.125"/>
      <inertia ixx="0.005" iyy="0.005" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.733" upper="1.571" effort="10.0" velocity="1.0"/>
  </joint>

  <!-- Link 3: wrist placeholder -->
  <link name="link_3">
    <visual>
      <geometry><sphere radius="0.03"/></geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="orange"><color rgba="0.9 0.5 0.1 1.0"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.553" upper="0.908" effort="10.0" velocity="1.0"/>
  </joint>

</robot>
